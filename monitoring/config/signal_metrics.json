{
  "_meta": {
    "description": "Signal quality metrics for the autoresearch loop. This is the 'val_bpb' equivalent — the evaluation metric that drives keep/discard decisions on query modifications. Updated after each monitoring run.",
    "version": "1.0",
    "created": "2026-03-16"
  },
  "metric_definitions": {
    "hs_disinfo_hit_rate": {
      "description": "% of findings that pass the Bridge Test as HS_DISINFO or VE_PROPAGANDA (not CONTEXT)",
      "target": ">= 0.80",
      "direction": "higher_is_better"
    },
    "new_handles_discovered": {
      "description": "Number of new accounts/channels/websites discovered per run that produce or amplify HS/disinfo",
      "target": ">= 1 per run average",
      "direction": "higher_is_better"
    },
    "country_coverage": {
      "description": "Number of countries (out of 3: South Sudan, Kenya, Somalia) with at least one finding per run",
      "target": ">= 2",
      "direction": "higher_is_better"
    },
    "source_diversity": {
      "description": "Number of distinct source publishers cited per run",
      "target": ">= 4",
      "direction": "higher_is_better"
    },
    "false_positive_rate": {
      "description": "% of findings initially logged as primary that should have been CONTEXT",
      "target": "<= 0.15",
      "direction": "lower_is_better"
    },
    "query_yield": {
      "description": "% of query categories that return at least one new finding per run",
      "target": ">= 0.30",
      "direction": "higher_is_better"
    }
  },
